    "ax.set_xlabel(\"Spatial frequency k (nm$^{-1}$)\")\n",
    "ax.set_ylabel(\"PSD $S_{yy}(k)$ (nm$^3$)\")\n",
    "ax.set_title(f\"PSD of Binned Roughness (bin = {BIN_PX} px)\")\n",
    "ax.legend()\n",
    "fig.tight_layout()\n",
    "savefig(fig, f\"binned_{BIN_PX}px_PSD_roughness\")\n",
    "plt.show()\n",
    "\n",
    "# --- Plot 2: PSD + fits -------------------------------------------------------\n",
    "def overlay_fit_line(kmin, kmax, fit, color, label):\n",
    "    if fit and np.isfinite(fit[\"slope\"]):\n",
