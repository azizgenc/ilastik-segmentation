    "import os\n",
    "from pathlib import Path\n",
    "from datetime import datetime             \n",
    "from typing import Optional\n",
    "\n",
    "def make_outdir(prob_path: str,\n",
    "                output_dir: Optional[str],\n",
    "                use_timestamp: bool,\n",
    "                save_prefix: str) -> Path:\n",
    "    \"\"\"\n",
    "    Decide and create the output directory.\n",
    "    - If output_dir is None: place next to PROB_PATH in a folder named SAVE_PREFIX\n",
    "    - Else: use OUTPUT_DIR (and optionally timestamped subfolder).\n",
    "    Returns a pathlib.Path to the folder.\n",
    "    \"\"\"\n",
    "    if output_dir is None or str(output_dir).strip() == \"\":\n",
    "        base = Path(prob_path).resolve().parent / save_prefix\n",
    "    else:\n",
    "        base = Path(output_dir).expanduser().resolve()\n",
    "\n",
    "    if use_timestamp:\n",
    "        ts = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",
    "        outdir = base / f\"{save_prefix}_{ts}\"\n",
    "    else:\n",
    "        outdir = base\n",
    "\n",
    "    outdir.mkdir(parents=True, exist_ok=True)\n",
    "    return outdir\n",
    "\n",
    "\n",
    "OUTDIR = make_outdir(PROB_PATH, OUTPUT_DIR, USE_TIMESTAMP_SUBFOLDER, SAVE_PREFIX)\n",
    "print(f\"[i] Output folder: {OUTDIR}\")\n",
    "\n",
    "def outpath(name: str, ext: str) -> Path:\n",
    "    \"\"\"\n",
    "    Build a standardized output path as: OUTDIR / f\"{SAVE_PREFIX}_{name}.{ext}\"\n",
    "    \"\"\"\n",
    "    cleaned = name.strip().replace(\" \", \"_\")\n",
    "    return OUTDIR / f\"{SAVE_PREFIX}_{cleaned}.{ext.lstrip('.')}\"\n",
    "\n",
    "\n",
