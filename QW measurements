    "# --- PSD of Binned Results: top/bottom δy and optional thickness --------------\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import json\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.integrate import trapezoid\n",
    "\n",
    "# -------------------- USER PARAMETERS -----------------------------------------\n",
    "INCLUDE_THICKNESS_PSD = True\n",
    "APPLY_LOG_BIN         = True\n",
    "LOG_BIN_PER_DEC       = 30\n",
    "FIT_BAND_MIN          = 0.005         # nm^-1\n",
    "FIT_BAND_MAX          = 0.5           # nm^-1\n",
    "# ------------------------------------------------------------------------------\n",
    "\n",
    "# -------------------- Safety checks -------------------------------------------\n",
    "_required = [\"x_b\", \"dt_top_b\", \"dt_bot_b\"]\n",
    "_missing = [v for v in _required if v not in globals()]\n",
    "if _missing:\n",
    "    raise RuntimeError(\n",
    "        f\"Binned PSD: missing variables {', '.join(_missing)}. \"\n",
    "        \"Run the binned plots cell first.\"\n",
    "    )\n",
    "\n",
    "# Filter out NaN x_b and keep order\n",
    "x_b = np.asarray(x_b, float)\n",
    "m_order = np.isfinite(x_b)\n",
    "if not np.all(m_order):\n",
    "    x_b = x_b[m_order]\n",
    "    dt_top_b = np.asarray(dt_top_b, float)[m_order]\n",
    "    dt_bot_b = np.asarray(dt_bot_b, float)[m_order]\n",
    "    if 'thick_b' in globals():\n",
    "        thick_b = np.asarray(thick_b, float)[m_order]\n",
    "\n",
    "# Need enough bins\n",
    "if x_b.size < 8:\n",
    "    raise ValueError(f\"Too few bins ({x_b.size}) for PSD. Increase image width or reduce BIN_PX.\")\n",
    "\n",
    "# Sampling step\n",
    "dx_b_nm = float(np.nanmedian(np.diff(x_b)))\n",
    "nyquist_b = 1.0 / (2.0 * dx_b_nm)\n",
    "\n",
    "# Clamp FIT_BAND_MAX if needed\n",
    "if FIT_BAND_MAX > nyquist_b:\n",
    "    print(f\"[Binned PSD] Adjusted FIT_BAND_MAX from {FIT_BAND_MAX:.4f} → Nyquist {nyquist_b:.4f} nm^-1\")\n",
    "    FIT_BAND_MAX = nyquist_b\n",
    "\n",
    "# -------------------- Helper functions ----------------------------------------\n",
    "def _interp_nans_1d(y):\n",
    "    y = np.asarray(y, dtype=float)\n",
    "    x = np.arange(y.size, dtype=float)  # <-- FIXED\n",
    "    m = np.isfinite(y)\n",
    "    if m.sum() >= 2:\n",
    "        y[~m] = np.interp(x[~m], x[m], y[m])\n",
    "    return y\n",
    "\n",
    "def one_sided_psd(delta_nm, dx_nm):\n",
    "    \"\"\"One-sided PSD using Hann window + rFFT.\"\"\"\n",
    "    y = _interp_nans_1d(np.asarray(delta_nm, float))\n",
    "    y -= np.mean(y)\n",
    "    n = len(y)\n",
    "    if n < 8:\n",
    "        raise ValueError(\"Series too short for PSD.\")\n",
    "    w = np.hanning(n)\n",
    "    U = (w**2).sum() / n\n",
    "    Y = np.fft.rfft(y * w)\n",
    "    k = np.fft.rfftfreq(n, d=dx_nm)\n",
    "    S = (dx_nm / (U * n)) * np.abs(Y)**2\n",
    "    # One-sided scaling\n",
    "    if n % 2 == 0:\n",
    "        if S.size > 2: S[1:-1] *= 2\n",
    "    else:\n",
    "        if S.size > 1: S[1:] *= 2\n",
    "    return k, S\n",
    "\n",
    "def log_bin_psd(k, S, points_per_decade=30):\n",
    "    m = (k > 0) & np.isfinite(S) & (S > 0)\n",
    "    k, S = k[m], S[m]\n",
    "    if k.size < 5:\n",
    "        return k, S\n",
    "\n",
    "    decades = np.log10([k.min(), k.max()])\n",
    "    n_bins = max(int((decades[1] - decades[0]) * points_per_decade), 1)\n",
    "    bins = np.logspace(decades[0], decades[1], n_bins + 1)\n",
    "\n",
    "    idx = np.digitize(k, bins)\n",
    "    kb, Sb = [], []\n",
    "    for b in range(1, len(bins)):\n",
    "        mm = idx == b\n",
    "        if np.any(mm):\n",
    "            kb.append(np.exp(np.mean(np.log(k[mm]))))\n",
    "            Sb.append(np.exp(np.mean(np.log(S[mm]))))\n",
    "    return np.array(kb), np.array(Sb)\n",
    "\n",
    "def fit_loglog_slope(k, S, kmin, kmax):\n",
    "    m = (k >= kmin) & (k <= kmax) & np.isfinite(S) & (S > 0)\n",
    "    if m.sum() < 5:\n",
    "        return dict(slope=np.nan, intercept=np.nan, n_points=int(m.sum()))\n",
    "    x = np.log10(k[m]); y = np.log10(S[m])\n",
    "    A = np.vstack([x, np.ones_like(x)]).T\n",
    "    slope, intercept = np.linalg.lstsq(A, y, rcond=None)[0]\n",
    "    return dict(slope=float(slope), intercept=float(intercept), n_points=int(m.sum()))\n",
    "\n",
    "# -------------------- Compute PSDs --------------------------------------------\n",
    "k_top_b, S_top_b = one_sided_psd(dt_top_b, dx_b_nm)\n",
    "k_bot_b, S_bot_b = one_sided_psd(dt_bot_b, dx_b_nm)\n",
    "\n",
    "# RMS from PSD and from profile\n",
    "Rq_top_b_psd     = float(np.sqrt(trapezoid(S_top_b, k_top_b)))\n",
    "Rq_bot_b_psd     = float(np.sqrt(trapezoid(S_bot_b, k_bot_b)))\n",
    "Rq_top_b_profile = float(np.sqrt(np.nanmean(np.asarray(dt_top_b, float)**2)))\n",
    "Rq_bot_b_profile = float(np.sqrt(np.nanmean(np.asarray(dt_bot_b, float)**2)))\n",
    "\n",
    "# Optional thickness PSD\n",
    "if INCLUDE_THICKNESS_PSD and 'thick_b' in globals():\n",
    "    k_th_b, S_th_b = one_sided_psd(thick_b - np.nanmean(thick_b), dx_b_nm)\n",
    "    has_thickness = True\n",
    "else:\n",
    "    has_thickness = False\n",
    "    k_th_b = S_th_b = None\n",
    "\n",
    "# Fitted slopes\n",
    "fit_top_b = fit_loglog_slope(k_top_b, S_top_b, FIT_BAND_MIN, FIT_BAND_MAX)\n",
    "fit_bot_b = fit_loglog_slope(k_bot_b, S_bot_b, FIT_BAND_MIN, FIT_BAND_MAX)\n",
    "fit_th_b  = fit_loglog_slope(k_th_b,  S_th_b,  FIT_BAND_MIN, FIT_BAND_MAX) if has_thickness else None\n",
    "\n",
    "# -------------------- Export CSV spectra --------------------------------------\n",
    "psd_df = pd.DataFrame({\n",
    "    \"k_nm^-1\": k_top_b,\n",
    "    \"PSD_top_binned_nm^3\": S_top_b,\n",
    "    \"PSD_bottom_binned_nm^3\": S_bot_b,\n",
    "})\n",
    "\n",
    "psd_csv = outpath(f\"binned_{BIN_PX}px_PSD_spectra\", \"csv\")\n",
    "psd_df.to_csv(psd_csv, index=False)\n",
    "print(f\"[Saved] {psd_csv}\")\n",
    "\n",
    "if has_thickness:\n",
    "    psd_th_df = pd.DataFrame({\n",
    "        \"k_nm^-1\": k_th_b,\n",
    "        \"PSD_thickness_binned_nm^3\": S_th_b\n",
    "    })\n",
    "    psd_th_csv = outpath(f\"binned_{BIN_PX}px_PSD_thickness_spectrum\", \"csv\")\n",
    "    psd_th_df.to_csv(psd_th_csv, index=False)\n",
    "    print(f\"[Saved] {psd_th_csv}\")\n",
    "else:\n",
    "    psd_th_csv = None\n",
    "\n",
    "# -------------------- Export JSON summary --------------------------------------\n",
    "psd_json = outpath(f\"binned_{BIN_PX}px_PSD_summary\", \"json\")\n",
    "with open(psd_json, \"w\", encoding=\"utf-8\") as f:\n",
    "    json.dump({\n",
    "        \"bin_px\": int(BIN_PX),\n",
    "        \"dx_binned_nm\": dx_b_nm,\n",
    "        \"Nyquist_nm^-1\": nyquist_b,\n",
    "        \"fit_band_nm^-1\": {\"min\": FIT_BAND_MIN, \"max\": FIT_BAND_MAX},\n",
    "        \"Rq_from_psd_nm\": {\"top\": Rq_top_b_psd, \"bottom\": Rq_bot_b_psd},\n",
    "        \"Rq_from_binned_profile_nm\": {\"top\": Rq_top_b_profile, \"bottom\": Rq_bot_b_profile},\n",
    "        \"consistency_ratios\": {\n",
    "            \"top_RqPSD_over_RqProfile\":\n",
    "                float(Rq_top_b_psd / Rq_top_b_profile) if Rq_top_b_profile > 0 else np.nan,\n",
    "            \"bottom_RqPSD_over_RqProfile\":\n",
    "                float(Rq_bot_b_psd / Rq_bot_b_profile) if Rq_bot_b_profile > 0 else np.nan,\n",
    "        },\n",
    "        \"top_fit_log10\": fit_top_b,\n",
    "        \"bottom_fit_log10\": fit_bot_b,\n",
    "        \"thickness_fit_log10\": fit_th_b,\n",
    "        \"files\": {\n",
    "            \"psd_csv\": str(psd_csv),\n",
    "            \"psd_thickness_csv\": str(psd_th_csv),\n",
    "            \"summary_json\": str(psd_json),\n",
    "        }\n",
    "    }, f, indent=2)\n",
    "\n",
    "print(f\"[Saved] {psd_json}\")\n",
    "\n",
    "# -------------------- PSD PLOTS -----------------------------------------------\n",
    "# Log-binned plots\n",
    "if APPLY_LOG_BIN:\n",
    "    k_top_plot, S_top_plot = log_bin_psd(k_top_b, S_top_b, LOG_BIN_PER_DEC)\n",
    "    k_bot_plot, S_bot_plot = log_bin_psd(k_bot_b, S_bot_b, LOG_BIN_PER_DEC)\n",
    "else:\n",
    "    k_top_plot, S_top_plot = k_top_b, S_top_b\n",
    "    k_bot_plot, S_bot_plot = k_bot_b, S_bot_b\n",
    "\n",
    "# --- Plot 1: PSD Top/Bottom ---------------------------------------------------\n",
    "fig, ax = plt.subplots(figsize=(7.6,5.6))\n",
    "ax.loglog(k_top_plot, S_top_plot, label=\"Top (binned δy)\", lw=1.2)\n",
    "ax.loglog(k_bot_plot, S_bot_plot, label=\"Bottom (binned δy)\", lw=1.2)\n",
