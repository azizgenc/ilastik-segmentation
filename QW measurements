    "# --- Sliding-window smoothing (centered moving average) -----------------------\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# --------------------- USER PARAMETERS ----------------------------------------\n",
    "WIN_PX = 5                        # sliding window width in pixels (>= 1)\n",
    "USE_MEDIAN = False                # set True to use median instead of mean\n",
    "# ------------------------------------------------------------------------------\n",
    "\n",
    "def rolling_reduce_nan(y, win, reduce='mean'):\n",
    "    \"\"\"\n",
    "    Centered sliding window reduction with NaN handling.\n",
    "    - 'mean' or 'median'\n",
    "    - Returns an array the same length as y.\n",
    "    - For ends: window is clipped; no padding.\n",
    "    \"\"\"\n",
    "    y = np.asarray(y, float)\n",
    "    n = y.size\n",
    "    if win < 1:\n",
    "        raise ValueError(\"Window must be >= 1\")\n",
    "    if win == 1:\n",
    "        return y.copy()\n",
    "\n",
    "    half = win // 2\n",
    "    out = np.full(n, np.nan)\n",
    "    for i in range(n):\n",
    "        s = max(0, i - half)\n",
    "        e = min(n, i + half + 1)\n",
    "        seg = y[s:e]\n",
    "        m = np.isfinite(seg)\n",
    "        if m.any():\n",
    "            out[i] = np.nanmedian(seg[m]) if reduce == 'median' else np.nanmean(seg[m])\n",
    "    return out\n",
    "\n",
    "# Choose reducer\n",
    "_reducer = 'median' if USE_MEDIAN else 'mean'\n",
    "\n",
    "# --- Compute sliding-window smoothed series -----------------------------------\n",
    "y_top_sw     = rolling_reduce_nan(y_top_nm,     WIN_PX, reduce=_reducer)\n",
    "y_bot_sw     = rolling_reduce_nan(y_bot_nm,     WIN_PX, reduce=_reducer)\n",
    "delta_top_sw = rolling_reduce_nan(delta_top_nm, WIN_PX, reduce=_reducer)\n",
    "delta_bot_sw = rolling_reduce_nan(delta_bot_nm, WIN_PX, reduce=_reducer)\n",
    "thick_sw     = rolling_reduce_nan(thickness_nm, WIN_PX, reduce=_reducer)\n",
    "\n",
    "# --- Save each series separately into OUTDIR ----------------------------------\n",
    "# 1) Interfaces\n",
    "df_if = pd.DataFrame({\n",
    "    \"x_nm\": x_nm,\n",
    "    \"top_interface_nm_raw\": y_top_nm,\n",
    "    f\"top_interface_nm_{_reducer}_{WIN_PX}px\": y_top_sw,\n",
    "    \"bottom_interface_nm_raw\": y_bot_nm,\n",
    "    f\"bottom_interface_nm_{_reducer}_{WIN_PX}px\": y_bot_sw,\n",
    "})\n",
    "csv_if = outpath(f\"sliding_interfaces_{_reducer}_{WIN_PX}px\", \"csv\")\n",
    "df_if.to_csv(csv_if, index=False)\n",
    "print(f\"[Saved] {csv_if}\")\n",
    "\n",
    "# 2) Detrended roughness\n",
    "df_ry = pd.DataFrame({\n",
    "    \"x_nm\": x_nm,\n",
    "    \"delta_top_nm_raw\": delta_top_nm,\n",
    "    f\"delta_top_nm_{_reducer}_{WIN_PX}px\": delta_top_sw,\n",
    "    \"delta_bottom_nm_raw\": delta_bot_nm,\n",
    "    f\"delta_bottom_nm_{_reducer}_{WIN_PX}px\": delta_bot_sw,\n",
    "})\n",
    "csv_ry = outpath(f\"sliding_roughness_{_reducer}_{WIN_PX}px\", \"csv\")\n",
    "df_ry.to_csv(csv_ry, index=False)\n",
    "print(f\"[Saved] {csv_ry}\")\n",
