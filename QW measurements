    "\n",
    "    decades = np.log10([k.min(), k.max()])\n",
    "    n_bins  = max(int((decades[1] - decades[0]) * points_per_decade), 1)\n",
    "    bins    = np.logspace(decades[0], decades[1], n_bins + 1)\n",
    "\n",
    "    idx = np.digitize(k, bins)\n",
    "    kb, Sb = [], []\n",
    "\n",
    "    for b in range(1, len(bins)):\n",
    "        mm = idx == b\n",
    "        if np.any(mm):\n",
    "            kb.append(np.exp(np.mean(np.log(k[mm]))))\n",
    "            Sb.append(np.exp(np.mean(np.log(S[mm]))))\n",
    "\n",
    "    return np.array(kb), np.array(Sb)\n",
    "\n",
    "def fit_loglog_slope(k, S, kmin, kmax):\n",
    "    m = (k >= kmin) & (k <= kmax) & np.isfinite(S) & (S > 0)\n",
    "    if m.sum() < 5:\n",
    "        return dict(slope=np.nan, intercept=np.nan, n_points=int(m.sum()))\n",
    "    x = np.log10(k[m])\n",
    "    y = np.log10(S[m])\n",
    "    A = np.vstack([x, np.ones_like(x)]).T\n",
    "    slope, intercept = np.linalg.lstsq(A, y, rcond=None)[0]\n",
    "    return dict(slope=float(slope), intercept=float(intercept), n_points=int(m.sum()))\n",
    "\n",
    "# -------------------- Compute PSDs (δy series) --------------------------------\n",
    "k_top_sw, S_top_sw = one_sided_psd(delta_top_sw, dx_nm)\n",
    "k_bot_sw, S_bot_sw = one_sided_psd(delta_bot_sw, dx_nm)\n",
    "\n",
    "# RMS via PSD and via direct profile\n",
    "Rq_top_sw_psd     = float(np.sqrt(trapezoid(S_top_sw, k_top_sw)))\n",
    "Rq_bot_sw_psd     = float(np.sqrt(trapezoid(S_bot_sw, k_bot_sw)))\n",
    "Rq_top_sw_profile = float(np.sqrt(np.nanmean(np.asarray(delta_top_sw, float)**2)))\n",
    "Rq_bot_sw_profile = float(np.sqrt(np.nanmean(np.asarray(delta_bot_sw, float)**2)))\n",
    "\n",
    "# -------------------- Optional thickness PSD ---------------------------------\n",
    "has_thickness = (\"thick_sw\" in globals())\n",
    "if has_thickness and INCLUDE_THICKNESS_PSD:\n",
    "    k_th_sw, S_th_sw = one_sided_psd(np.asarray(thick_sw, float) - np.nanmean(thick_sw), dx_nm)\n",
    "else:\n",
    "    k_th_sw = None\n",
    "    S_th_sw = None\n",
    "\n",
    "# Fit slopes\n",
    "fit_top_sw = fit_loglog_slope(k_top_sw, S_top_sw, FIT_BAND_MIN, FIT_BAND_MAX)\n",
    "fit_bot_sw = fit_loglog_slope(k_bot_sw, S_bot_sw, FIT_BAND_MIN, FIT_BAND_MAX)\n",
    "fit_th_sw  = fit_loglog_slope(k_th_sw,  S_th_sw,  FIT_BAND_MIN, FIT_BAND_MAX) \\\n",
    "             if (k_th_sw is not None) else None\n",
    "\n",
    "# -------------------- Export CSV spectra --------------------------------------\n",
    "psd_df = pd.DataFrame({\n",
    "    \"k_nm^-1\":                 k_top_sw,\n",
    "    \"PSD_top_sliding_nm^3\":    S_top_sw,\n",
    "    \"PSD_bottom_sliding_nm^3\": S_bot_sw,\n",
    "})\n",
    "psd_csv = outpath(f\"sliding_{WIN_PX}px_PSD_spectra\", \"csv\")\n",
    "psd_df.to_csv(psd_csv, index=False)\n",
    "print(f\"[Saved] {psd_csv}\")\n",
    "\n",
    "if (k_th_sw is not None):\n",
    "    psd_th_df = pd.DataFrame({\n",
    "        \"k_nm^-1\": k_th_sw,\n",
    "        \"PSD_thickness_sliding_nm^3\": S_th_sw\n",
    "    })\n",
    "    psd_th_csv = outpath(f\"sliding_{WIN_PX}px_PSD_thickness_spectrum\", \"csv\")\n",
    "    psd_th_df.to_csv(psd_th_csv, index=False)\n",
    "    print(f\"[Saved] {psd_th_csv}\")\n",
    "else:\n",
    "    psd_th_csv = None\n",
    "\n",
    "# -------------------- Export JSON summary -------------------------------------\n",
    "psd_json = outpath(f\"sliding_{WIN_PX}px_PSD_summary\", \"json\")\n",
    "with open(psd_json, \"w\", encoding=\"utf-8\") as f:\n",
    "    json.dump({\n",
    "        \"window_px\": int(WIN_PX),\n",
    "        \"dx_nm\": dx_nm,\n",
    "        \"Nyquist_nm^-1\": nyquist,\n",
    "        \"fit_band_nm^-1\": {\"min\": FIT_BAND_MIN, \"max\": FIT_BAND_MAX},\n",
    "\n",
    "        \"Rq_from_psd_nm\": {\n",
    "            \"top\": Rq_top_sw_psd,\n",
    "            \"bottom\": Rq_bot_sw_psd\n",
    "        },\n",
    "        \"Rq_from_smoothed_profile_nm\": {\n",
    "            \"top\": Rq_top_sw_profile,\n",
    "            \"bottom\": Rq_bot_sw_profile\n",
    "        },\n",
    "\n",
    "        \"consistency_ratios\": {\n",
    "            \"top_RqPSD_over_RqProfile\":\n",
    "                float(Rq_top_sw_psd / Rq_top_sw_profile) if Rq_top_sw_profile > 0 else np.nan,\n",
    "            \"bottom_RqPSD_over_RqProfile\":\n",
    "                float(Rq_bot_sw_psd / Rq_bot_sw_profile) if Rq_bot_sw_profile > 0 else np.nan,\n",
    "        },\n",
    "\n",
    "        \"top_fit_log10\": fit_top_sw,\n",
    "        \"bottom_fit_log10\": fit_bot_sw,\n",
    "        \"thickness_fit_log10\": fit_th_sw,\n",
    "\n",
    "        \"files\": {\n",
    "            \"psd_csv\": str(psd_csv),\n",
    "            \"psd_thickness_csv\": str(psd_th_csv),\n",
    "            \"summary_json\": str(psd_json),\n",
    "        }\n",
    "    }, f, indent=2)\n",
    "\n",
    "print(f\"[Saved] {psd_json}\")\n",
    "\n",
    "# -------------------- Plotting (log-binned for readability) -------------------\n",
    "if APPLY_LOG_BIN:\n",
    "    k_top_plot, S_top_plot = log_bin_psd(k_top_sw, S_top_sw, LOG_BIN_PER_DEC)\n",
    "    k_bot_plot, S_bot_plot = log_bin_psd(k_bot_sw, S_bot_sw, LOG_BIN_PER_DEC)\n",
    "else:\n",
    "    k_top_plot, S_top_plot = k_top_sw, S_top_sw\n",
    "    k_bot_plot, S_bot_plot = k_bot_sw, S_bot_sw\n",
    "\n",
    "# --- Plot 1: δy PSD (Top/Bottom) ----------------------------------------------\n",
    "fig, ax = plt.subplots(figsize=(7.6,5.6))\n",
    "ax.loglog(k_top_plot, S_top_plot, lw=1.2, label=f\"Top δy (SW {WIN_PX}px)\")\n",
    "ax.loglog(k_bot_plot, S_bot_plot, lw=1.2, label=f\"Bottom δy (SW {WIN_PX}px)\")\n",
    "\n",
    "ax.axvspan(FIT_BAND_MIN, FIT_BAND_MAX, color=\"gray\", alpha=0.15, label=\"Fit band\")\n",
    "ax.set_xlabel(\"Spatial frequency k (nm$^{-1}$)\")\n",
    "ax.set_ylabel(\"PSD $S_{yy}(k)$ (nm$^3$)\")\n",
    "ax.set_title(f\"PSD of Sliding-Window Roughness (window = {WIN_PX} px)\")\n",
    "ax.legend()\n",
    "fig.tight_layout()\n",
    "savefig(fig, f\"sliding_{WIN_PX}px_PSD_roughness\")\n",
    "plt.show()\n",
    "\n",
    "# Helper for overlaying fit lines\n",
    "def overlay_fit_line(kmin, kmax, fit, color, label):\n",
    "    if fit and np.isfinite(fit[\"slope\"]):\n",
    "        k_line = np.logspace(np.log10(kmin), np.log10(kmax), 200)\n",
    "        S_line = (10**fit[\"intercept\"]) * (k_line**fit[\"slope\"])\n",
    "        plt.loglog(k_line, S_line, \"--\", lw=1.1, alpha=0.85,\n",
    "                   color=color, label=f\"{label}: slope={fit['slope']:.2f}\")\n",
    "\n",
    "# --- Plot 2: δy PSD with fits --------------------------------------------------\n",
    "fig, ax = plt.subplots(figsize=(7.6,5.2))\n",
    "ax.loglog(k_top_plot, S_top_plot, color=\"#1f77b4\", lw=1.2, label=\"Top (SW)\")\n",
    "overlay_fit_line(FIT_BAND_MIN, FIT_BAND_MAX, fit_top_sw, \"#1f77b4\", \"Top fit\")\n",
    "\n",
    "ax.loglog(k_bot_plot, S_bot_plot, color=\"#ff7f0e\", lw=1.2, label=\"Bottom (SW)\")\n",
    "overlay_fit_line(FIT_BAND_MIN, FIT_BAND_MAX, fit_bot_sw, \"#ff7f0e\", \"Bottom fit\")\n",
    "\n",
    "ax.axvspan(FIT_BAND_MIN, FIT_BAND_MAX, color='gray', alpha=0.15)\n",
    "ax.set_xlabel(\"Spatial frequency k (nm$^{-1}$)\")\n",
    "ax.set_ylabel(\"PSD $S_{yy}(k)$ (nm$^3$)\")\n",
    "ax.set_title(\"PSD of Sliding-Window Roughness with Power-law Fits\")\n",
    "ax.legend()\n",
    "fig.tight_layout()\n",
    "savefig(fig, f\"sliding_{WIN_PX}px_PSD_roughness_fits\")\n",
    "plt.show()\n",
    "\n",
    "# --- Plot 3: Thickness PSD (optional) ------------------------------------------\n",
    "if (k_th_sw is not None):\n",
    "    if APPLY_LOG_BIN:\n",
    "        k_th_plot, S_th_plot = log_bin_psd(k_th_sw, S_th_sw, LOG_BIN_PER_DEC)\n",
    "    else:\n",
    "        k_th_plot, S_th_plot = k_th_sw, S_th_sw\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(7.2,5.0))\n",
    "    ax.loglog(k_th_plot, S_th_plot, color=\"#2ca02c\", lw=1.2,\n",
    "              label=f\"Thickness (SW {WIN_PX}px)\")\n",
    "    overlay_fit_line(FIT_BAND_MIN, FIT_BAND_MAX, fit_th_sw, \"#2ca02c\", \"Thickness fit\")\n",
    "\n",
    "    ax.axvspan(FIT_BAND_MIN, FIT_BAND_MAX, color='gray', alpha=0.15)\n",
    "    ax.set_xlabel(\"Spatial frequency k (nm$^{-1}$)\")\n",
    "    ax.set_ylabel(\"PSD $S_{tt}(k)$ (nm$^3$)\")\n",
    "    ax.set_title(\"PSD of Sliding-Window Thickness\")\n",
    "    ax.legend()\n",
    "    fig.tight_layout()\n",
    "    savefig(fig, f\"sliding_{WIN_PX}px_PSD_thickness\")\n",
    "    plt.show()"
   ]
