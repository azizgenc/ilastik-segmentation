    "def one_sided_psd(delta, dx):\n",
    "    y = np.asarray(delta, float)\n",
    "    x = np.arange(len(y))\n",
    "    m = np.isfinite(y)\n",
    "    if m.sum() >= 2:\n",
    "        y[~m] = np.interp(x[~m], x[m], y[m])\n",
    "    y -= np.mean(y)\n",
    "\n",
    "    n = len(y)\n",
    "    if n < 8:\n",
    "        raise ValueError(\"PSD requires length >= 8.\")\n",
    "\n",
    "    w = np.hanning(n)\n",
    "    U = (w*w).sum() / n\n",
    "    Y = np.fft.rfft(y * w)\n",
    "    k = np.fft.rfftfreq(n, d=dx)\n",
    "    S = (dx / (U*n)) * np.abs(Y)**2\n",
    "\n",
    "    if n % 2 == 0 and len(S) > 2:\n",
    "        S[1:-1] *= 2\n",
    "    elif n % 2 == 1 and len(S) > 1:\n",
    "        S[1:] *= 2\n",
    "\n",
    "    return k, S"
   ]
