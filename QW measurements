    "# ================= Cell D (MAD outliers + neighbor replace) ===================\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import json\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# --------------------- USER PARAMETERS: Outlier handling ----------------------\n",
    "OUTLIER_METHOD          = \"combined\"  \n",
    "OUTLIER_ABS_NM          = 0.7\n",
    "OUTLIER_MULTIPLIER_RA   = 5.0\n",
    "MAD_K                   = 5.0\n",
    "NEIGHBOR_COUNT          = 10\n",
    "REDETREND_AFTER_FIX     = True\n",
    "# -----------------------------------------------------------------------------\n",
    "\n",
    "\n",
    "def _poly_detrend(x, y, deg=1):\n",
    "    x = np.asarray(x, float)\n",
    "    y = np.asarray(y, float)\n",
    "    m = np.isfinite(x) & np.isfinite(y)\n",
    "    if m.sum() < deg + 1:\n",
    "        yfit = np.full_like(y, np.nan)\n",
    "        return yfit, y - yfit\n",
    "    coef = np.polyfit(x[m], y[m], deg)\n",
    "    yfit = np.polyval(coef, x)\n",
    "    return yfit, y - yfit\n",
    "\n",
    "\n",
    "def _roughness_metrics(delta_nm):\n",
    "    d = np.asarray(delta_nm, float)\n",
    "    d = d[np.isfinite(d)]\n",
    "    if d.size == 0:\n",
    "        return dict(Ra=np.nan, Rq=np.nan, PV=np.nan)\n",
    "    Ra = float(np.mean(np.abs(d)))\n",
    "    Rq = float(np.sqrt(np.mean(d**2)))\n",
    "    PV = float(np.nanmax(d) - np.nanmin(d))\n",
    "    return dict(Ra=Ra, Rq=Rq, PV=PV)\n",
    "\n",
    "\n",
    "def _corr_length_nm(delta_nm, dx_nm):\n",
    "    \"\"\"AUTOCORRELATION LENGTH (FIXED VERSION WITH dtype=float)\"\"\"\n",
    "    d = np.asarray(delta_nm, float).copy()\n",
    "    n = d.size\n",
    "    if n < 8:\n",
    "        return np.nan\n",
    "\n",
    "    x = np.arange(n, dtype=float)  # <-- FIXED: dtype=float required\n",
    "    m = np.isfinite(d)\n",
    "    if m.sum() < 3:\n",
    "        return np.nan\n",
    "\n",
    "    # fill NaNs by linear interpolation\n",
    "    d[~m] = np.interp(x[~m], x[m], d[m])\n",
    "    d = d - np.mean(d)\n",
    "    if np.allclose(d, 0):\n",
    "        return np.nan\n",
    "\n",
    "    ac = np.correlate(d, d, mode=\"full\")\n",
    "    ac = ac[ac.size // 2:]\n",
    "    ac = ac / ac[0]\n",
    "\n",
    "    target = 1.0 / np.e\n",
    "    idx = np.where(ac <= target)[0]\n",
    "    if idx.size == 0:\n",
    "        return np.nan\n",
    "\n",
    "    k = idx[0]\n",
    "    if k == 0:\n",
    "        return 0.0\n",
    "\n",
    "    x0, x1 = k - 1, k\n",
    "    y0, y1 = ac[x0], ac[x1]\n",
    "    lag = float(k) if y1 == y0 else x0 + (target - y0) / (y1 - y0)\n",
    "\n",
    "    return lag * dx_nm\n",
    "\n",
    "\n",
    "def _mad_sigma_hat(d):\n",
    "    d = np.asarray(d, float)\n",
    "    d = d[np.isfinite(d)]\n",
    "    if d.size == 0:\n",
    "        return np.nan\n",
    "    med = np.median(d)\n",
    "    mad = np.median(np.abs(d - med))\n",
    "    return 1.4826 * mad\n",
    "\n",
    "\n",
    "def _threshold_from_method(delta_nm, method, abs_thr_nm, ra_mult, mad_k):\n",
    "    d = np.asarray(delta_nm, float)\n",
    "    d = d[np.isfinite(d)]\n",
    "    if d.size == 0:\n",
    "        return abs_thr_nm\n",
    "\n",
    "    thr = []\n",
    "\n",
    "    if method in (\"abs+RA\", \"combined\"):\n",
    "        Ra = np.mean(np.abs(d))\n",
    "        thr.append(abs_thr_nm)\n",
    "        thr.append(ra_mult * Ra)\n",
    "\n",
    "    if method in (\"mad\", \"combined\"):\n",
    "        sigma_hat = _mad_sigma_hat(d)\n",
    "        thr.append(mad_k * sigma_hat if np.isfinite(sigma_hat) else abs_thr_nm)\n",
    "\n",
    "    if method == \"abs+RA\":\n",
    "        return max(thr)\n",
    "    elif method == \"mad\":\n",
    "        return thr[-1]\n",
    "    else:\n",
    "        return max(thr)\n",
    "\n",
    "\n",
    "def _replace_with_nearest_mean(y, outlier_mask, k=7):\n",
    "    y = np.asarray(y, float).copy()\n",
    "    n = y.size\n",
    "    idx = np.arange(n)\n",
    "\n",
    "    good = (~outlier_mask) & np.isfinite(y)\n",
    "    good_idx = idx[good]\n",
    "\n",
    "    if good_idx.size == 0:\n",
    "        return y\n",
    "\n",
    "    for i in np.where(outlier_mask)[0]:\n",
    "        d = np.abs(good_idx - i)\n",
    "        nn = good_idx[np.argsort(d)[:min(k, good_idx.size)]]\n",
    "        if nn.size > 0:\n",
    "            y[i] = np.nanmean(y[nn])\n",
    "\n",
    "    return y\n",
    "\n",
    "\n",
    "# -------------------------------------------------------------------------\n",
    "# 1) Initial detrend\n",
    "# -------------------------------------------------------------------------\n",
    "yfit_top0, resid_top_px0 = _poly_detrend(x_arr, y_top, deg=DETREND_DEG)\n",
    "yfit_bot0, resid_bot_px0 = _poly_detrend(x_arr, y_bot, deg=DETREND_DEG)\n",
    "\n",
    "delta_top_nm0 = resid_top_px0 * PX_NM\n",
    "delta_bot_nm0 = resid_bot_px0 * PX_NM\n",
    "\n",
    "# -------------------------------------------------------------------------\n",
    "# 2) Thresholds for outlier detection\n",
    "# -------------------------------------------------------------------------\n",
    "thr_top_nm = _threshold_from_method(delta_top_nm0, OUTLIER_METHOD,\n",
    "                                    OUTLIER_ABS_NM, OUTLIER_MULTIPLIER_RA, MAD_K)\n",
    "\n",
    "thr_bot_nm = _threshold_from_method(delta_bot_nm0, OUTLIER_METHOD,\n",
    "                                    OUTLIER_ABS_NM, OUTLIER_MULTIPLIER_RA, MAD_K)\n",
    "\n",
    "mask_outlier_top = np.abs(delta_top_nm0) > thr_top_nm\n",
    "mask_outlier_bot = np.abs(delta_bot_nm0) > thr_bot_nm\n",
    "mask_outlier_any = mask_outlier_top | mask_outlier_bot\n",
    "\n",
    "print(f\"[Outliers] Top: {np.sum(mask_outlier_top)}   Bottom: {np.sum(mask_outlier_bot)}\")\n",
    "\n",
    "\n",
    "# -------------------------------------------------------------------------\n",
    "# 3) Replace outliers by nearest-neighbor mean\n",
    "# -------------------------------------------------------------------------\n",
    "y_top_fixed = _replace_with_nearest_mean(y_top, mask_outlier_top, k=NEIGHBOR_COUNT)\n",
