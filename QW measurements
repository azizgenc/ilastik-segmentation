    "#  LOAD PROBABILITIES \n",
    "import numpy as np\n",
    "\n",
    "def _ensure_hw_c_last(arr):\n",
    "    arr = np.asarray(arr)\n",
    "    if arr.ndim == 2:\n",
    "        return arr[..., None]\n",
    "    if arr.ndim == 3 and arr.shape[0] <= 4:\n",
    "        # (C,H,W) -> (H,W,C)\n",
    "        return np.moveaxis(arr, 0, -1)\n",
    "    return arr\n",
    "\n",
    "def load_probabilities_any(path, qw_channel=0):\n",
    "    import os\n",
    "    ext = os.path.splitext(path)[1].lower()\n",
    "    if ext in {\".h5\", \".hdf5\"}:\n",
    "        import h5py\n",
    "        with h5py.File(path, \"r\") as f:\n",
    "            for key in [\"/exported_data\", \"exported_data\", \"data\"]:\n",
    "                if key in f:\n",
    "                    arr = np.asarray(f[key])\n",
    "                    break\n",
    "            else:\n",
    "                # fallback: first dataset\n",
    "                def _first_dataset(h):\n",
    "                    for k, v in h.items():\n",
    "                        if isinstance(v, h5py.Dataset):\n",
    "                            return k\n",
    "                        elif isinstance(v, h5py.Group):\n",
    "                            r = _first_dataset(v)\n",
    "                            if r is not None:\n",
    "                                return f\"{k}/{r}\"\n",
    "                    return None\n",
    "                ds = _first_dataset(f)\n",
    "                if ds is None:\n",
    "                    raise RuntimeError(\"No dataset found in HDF5 file.\")\n",
    "                arr = np.asarray(f[ds])\n",
    "        arr = _ensure_hw_c_last(arr).astype(np.float32)\n",
    "        if np.issubdtype(arr.dtype, np.integer):\n",
    "            maxv = np.iinfo(arr.dtype).max\n",
    "            arr = arr.astype(np.float32) / float(maxv)\n",
    "        return arr[..., qw_channel], arr\n",
    "\n",
    "    # Try tifffile first\n",
    "    try:\n",
    "        import tifffile\n",
    "        arr = tifffile.imread(path)\n",
    "        arr = _ensure_hw_c_last(arr)\n",
    "        if np.issubdtype(arr.dtype, np.integer):\n",
    "            maxv = np.iinfo(arr.dtype).max\n",
    "            arr = arr.astype(np.float32) / float(maxv)\n",
    "        return arr[..., qw_channel], arr\n",
    "    except Exception as e:\n",
    "        print(f\"tifffile failed ({e}); trying Pillow...\")\n",
    "\n",
    "    # Fallback: Pillow\n",
    "    from PIL import Image\n",
    "    im = Image.open(path)\n",
    "    frames = []\n",
    "    try:\n",
    "        i = 0\n",
    "        while True:\n",
    "            im.seek(i)\n",
    "            frames.append(np.array(im))\n",
    "            i += 1\n",
    "    except EOFError:\n",
    "        pass\n",
    "    arr = np.stack(frames, axis=-1) if len(frames) > 1 else np.array(im)[..., None]\n",
    "    if np.issubdtype(arr.dtype, np.integer):\n",
    "        maxv = np.iinfo(arr.dtype).max\n",
    "        arr = arr.astype(np.float32) / float(maxv)\n",
    "    arr = _ensure_hw_c_last(arr)\n",
    "    return arr[..., qw_channel], arr\n",
    "\n",
    "# ---- load and orient\n",
    "pq, prob_all = load_probabilities_any(PROB_PATH, qw_channel=QW_CHANNEL)\n",
    "H, W = pq.shape\n",
    "print(f\"[Loader] Loaded QW probability channel: {pq.shape} from {PROB_PATH}\")\n",
    "\n",
