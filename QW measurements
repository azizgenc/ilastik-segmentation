    "# --- Binned plots for interfaces, roughness, and thickness --------------------\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# --------------------- USER PARAMETERS ----------------------------------------\n",
    "BIN_PX = 5               # <- bin width in pixels (lateral direction)\n",
    "# ------------------------------------------------------------------------------\n",
    "\n",
    "def bin_1d(y, bin_px, x=None, reduce='mean'):\n",
    "    \"\"\"\n",
    "    Bin a 1D series in contiguous, non-overlapping bins of width `bin_px`.\n",
    "    - If x is given, it is also binned by mean (for plotting on bin centers).\n",
    "    - NaNs are ignored in the reducer; if a bin has all NaNs, result is NaN.\n",
    "    - reduce: 'mean' or 'median'\n",
    "    Returns (yb, xb, n_per_bin)\n",
    "    \"\"\"\n",
    "    y = np.asarray(y, dtype=float)\n",
    "    n = len(y)\n",
    "    nb = int(np.ceil(n / bin_px))\n",
    "    yb = np.empty(nb, dtype=float)\n",
    "    xb = None if x is None else np.empty(nb, dtype=float)\n",
    "    counts = np.zeros(nb, dtype=int)\n",
    "\n",
    "    if x is not None:\n",
    "        x = np.asarray(x, dtype=float)\n",
    "\n",
    "    for i in range(nb):\n",
    "        s = i * bin_px\n",
    "        e = min((i + 1) * bin_px, n)\n",
    "        seg = y[s:e]\n",
    "        m = np.isfinite(seg)\n",
    "\n",
    "        if m.any():\n",
    "            yb[i] = np.nanmedian(seg[m]) if reduce == 'median' else np.nanmean(seg[m])\n",
    "            counts[i] = m.sum()\n",
    "        else:\n",
    "            yb[i] = np.nan\n",
    "            counts[i] = 0\n",
    "\n",
    "        if x is not None:\n",
    "            segx = x[s:e]\n",
    "            mx = np.isfinite(segx)\n",
    "            xb[i] = np.nanmean(segx[mx]) if mx.any() else np.nan\n",
    "\n",
    "    return yb, xb, counts\n",
    "\n",
    "\n",
    "# --- Compute binned series -----------------------------------------------------\n",
    "# Lateral coordinate in nm is x_nm (length W)\n",
    "y_top_b,  x_b, n_top   = bin_1d(y_top_nm,     BIN_PX, x=x_nm, reduce='mean')\n",
    "y_bot_b,  _,   n_bot   = bin_1d(y_bot_nm,     BIN_PX, x=x_nm, reduce='mean')\n",
    "\n",
    "dt_top_b, _, _ = bin_1d(delta_top_nm, BIN_PX, x=x_nm, reduce='mean')\n",
    "dt_bot_b, _, _ = bin_1d(delta_bot_nm, BIN_PX, x=x_nm, reduce='mean')\n",
    "\n",
    "thick_b,  _, n_thick = bin_1d(thickness_nm, BIN_PX, x=x_nm, reduce='mean')\n",
    "\n",
    "# --- Optional binned trend lines ----------------------------------------------\n",
    "try:\n",
    "    yfit_top_b, _, _ = bin_1d(yfit_top_nm, BIN_PX, x=x_nm, reduce='mean')\n",
    "    yfit_bot_b, _, _ = bin_1d(yfit_bot_nm, BIN_PX, x=x_nm, reduce='mean')\n",
    "except NameError:\n",
    "    yfit_top_b = None\n",
    "    yfit_bot_b = None\n",
    "\n",
    "\n",
    "# --- Export binned profiles to CSV --------------------------------------------\n",
    "binned_df = pd.DataFrame({\n",
    "    \"x_binned_nm\": x_b,\n",
    "    \"n_points_per_bin\": n_top,\n",
