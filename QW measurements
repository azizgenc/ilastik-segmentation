    "from scipy.ndimage import gaussian_filter, binary_fill_holes\n",
    "from skimage.morphology import opening, closing, remove_small_objects, square\n",
    "from packaging.version import Version\n",
    "from skimage import __version__ as _skver\n",
    "\n",
    "def ensure_hw_c_last(arr):\n",
    "    arr = np.asarray(arr)\n",
    "    if arr.ndim == 2:    \n",
    "        return arr[..., None]\n",
    "    if arr.ndim == 3 and arr.shape[0] <= 4:\n",
    "        return np.moveaxis(arr, 0, -1)\n",
    "    return arr\n",
    "\n",
    "def load_probabilities(path, qw_channel=0):\n",
    "    \"\"\" Clean, minimal TIFF loader with imagecodecs support \"\"\"\n",
    "    arr = imread(str(path))  # works with LZW, JPEG, DEFLATE via imagecodecs\n",
    "    arr = ensure_hw_c_last(arr)\n",
    "    arr = arr.astype(np.float32)\n",
    "    return arr[..., qw_channel], arr\n",
    "\n",
    "def make_mask(prob, thr, smooth_sigma, min_obj):\n",
    "    p = gaussian_filter(prob, smooth_sigma) if smooth_sigma else prob\n",
    "    mask = p > thr\n",
    "    mask = binary_fill_holes(mask)\n",
    "    mask = opening(mask, square(3))\n",
    "    mask = closing(mask, square(3))\n",
    "\n",
    "    if Version(_skver) >= Version(\"0.26\"):\n",
    "        mask = remove_small_objects(mask, max_size=max(min_obj - 1, 0))\n",
    "    else:\n",
    "        mask = remove_small_objects(mask, min_size=min_obj)\n",
    "\n",
    "    return mask, p\n",
    "\n",
    "def subpixel_crossing(col, thr, from_top=True):\n",
    "    cp = np.asarray(col, float)\n",
    "    idx = np.where(cp >= thr)[0]\n",
    "    if len(idx) == 0:\n",
    "        return np.nan\n",
    "\n",
    "    if from_top:\n",
    "        k = max(idx[0]-1, 0)\n",
    "        y0, y1 = k, min(k+1, cp.size-1)\n",
    "    else:\n",
    "        k = idx[-1]\n",
    "        y0, y1 = max(k-1, 0), k\n",
    "\n",
    "    p0, p1 = cp[y0], cp[y1]\n",
    "    if p0 == p1: \n",
    "        return float(y1)\n",
    "\n",
    "    return float(y0 + (thr - p0) / (p1 - p0))\n",
    "\n",
    "def interp_nan(y):\n",
    "    y = np.asarray(y, float)\n",
    "    x = np.arange(len(y), float)\n",
    "    m = np.isfinite(y)\n",
    "    if m.sum() >= 2:\n",
    "        y[~m] = np.interp(x[~m], x[m], y[m])\n",
    "    return y\n",
    "\n",
    "def poly_detrend(x, y, deg):\n",
    "    x = np.asarray(x, float)\n",
    "    y = np.asarray(y, float)\n",
    "    m = np.isfinite(x) & np.isfinite(y)\n",
    "    if m.sum() < deg + 1:\n",
    "        return np.full_like(y, np.nan), np.full_like(y, np.nan)\n",
    "    c = np.polyfit(x[m], y[m], deg)\n",
    "    yfit = np.polyval(c, x)\n",
    "    return yfit, y - yfit\n",
    "\n",
    "def roughness(delta):\n",
    "    d = np.asarray(delta, float)\n",
    "    d = d[np.isfinite(d)]\n",
