    "# ========================================================================\n",
    "#   QW ROUGHNESS SUMMARY: Raw vs Binned vs Sliding-Window\n",
    "#\n",
    "#   Saves to OUTDIR using outpath():\n",
    "#       • <SAVE_PREFIX>_QW_roughness_combined_table.csv\n",
    "#       • <SAVE_PREFIX>_QW_roughness_combined_full.json\n",
    "#       • <SAVE_PREFIX>_QW_roughness_Rq_comparison.png\n",
    "# ========================================================================\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import json\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.integrate import trapezoid\n",
    "from IPython.display import display\n",
    "\n",
    "# ------------------------------ OPTIONS ---------------------------------\n",
    "MAKE_RQ_COMPARISON_PLOT = True\n",
    "REDUCE_BIN_NAN_EDGE     = True\n",
    "# -------------------------------------------------------------------------\n",
    "\n",
    "# ------------------------ Validation ------------------------------------\n",
    "needed = [\n",
    "    \"delta_top_nm\", \"delta_bot_nm\",\n",
    "    \"dt_top_b\", \"dt_bot_b\", \"x_b\",\n",
    "    \"delta_top_sw\", \"delta_bot_sw\"\n",
    "]\n",
    "missing = [v for v in needed if v not in globals()]\n",
    "if missing:\n",
    "    raise RuntimeError(\"Missing variables for summary: \" + \", \".join(missing))\n",
    "\n",
    "# ----------------- Metric helpers ---------------------------------------\n",
    "def _metrics_from_series(delta_nm, dx_nm):\n",
    "    d = np.asarray(delta_nm, float)\n",
    "    d = d[np.isfinite(d)]\n",
    "    if d.size == 0:\n",
    "        return dict(Ra=np.nan, Rq=np.nan, PV=np.nan, xi_nm=np.nan)\n",
    "\n",
    "    Ra = float(np.mean(np.abs(d)))\n",
    "    Rq = float(np.sqrt(np.mean(d**2)))\n",
    "    PV = float(np.nanmax(d) - np.nanmin(d))\n",
    "    xi = float(_corr_length_nm(d, dx_nm))\n",
    "    return dict(Ra=Ra, Rq=Rq, PV=PV, xi_nm=xi)\n",
    "\n",
    "def _psd_slope_and_rq(delta_nm, dx_nm, kmin, kmax):\n",
    "    k, S = one_sided_psd(delta_nm, dx_nm)\n",
    "    fit = fit_loglog_slope(k, S, kmin, kmax)\n",
    "\n",
    "    Rq_psd = float(np.sqrt(trapezoid(S, k)))\n",
    "    Rq_prof = float(np.sqrt(np.nanmean(np.asarray(delta_nm, float)**2)))\n",
    "\n",
    "    ratio = float(Rq_psd / Rq_prof) if Rq_prof > 0 else np.nan\n",
    "\n",
    "    return dict(\n",
    "        k=k, S=S,\n",
    "        fit=fit,\n",
    "        Rq_psd=Rq_psd,\n",
    "        Rq_profile=Rq_prof,\n",
    "        Rq_ratio=ratio\n",
    "    )\n",
    "\n",
    "# ------------------ Clean binned (OPTIONAL) ------------------------------\n",
    "if REDUCE_BIN_NAN_EDGE:\n",
    "    m_b = np.isfinite(x_b)\n",
    "    dt_top_b_clean = dt_top_b[m_b]\n",
    "    dt_bot_b_clean = dt_bot_b[m_b]\n",
    "    x_b_clean      = x_b[m_b]\n",
    "else:\n",
    "    dt_top_b_clean = dt_top_b\n",
    "    dt_bot_b_clean = dt_bot_b\n",
    "    x_b_clean      = x_b\n",
    "\n",
    "dx_raw = PX_NM\n",
    "dx_bin = float(np.nanmedian(np.diff(x_b_clean))) if len(x_b_clean) > 1 else PX_NM\n",
    "nyq_raw = 1/(2*dx_raw)\n",
    "nyq_bin = 1/(2*dx_bin)\n",
    "\n",
    "kmin = float(FIT_BAND_MIN)\n",
    "kmax_raw = float(min(FIT_BAND_MAX, nyq_raw))\n",
    "kmax_bin = float(min(FIT_BAND_MAX, nyq_bin))\n",
    "\n",
    "# ------------------- Compute metrics: RAW --------------------------------\n",
    "met_top_raw = _metrics_from_series(delta_top_nm, dx_raw)\n",
    "met_bot_raw = _metrics_from_series(delta_bot_nm, dx_raw)\n",
    "\n",
    "psd_top_raw = _psd_slope_and_rq(delta_top_nm, dx_raw, kmin, kmax_raw)\n",
    "psd_bot_raw = _psd_slope_and_rq(delta_bot_nm, dx_raw, kmin, kmax_raw)\n",
    "\n",
    "# ------------------- Compute metrics: BINNED ------------------------------\n",
    "met_top_bin = _metrics_from_series(dt_top_b_clean, dx_bin)\n",
    "met_bot_bin = _metrics_from_series(dt_bot_b_clean, dx_bin)\n",
    "\n",
    "psd_top_bin = _psd_slope_and_rq(dt_top_b_clean, dx_bin, kmin, kmax_bin)\n",
    "psd_bot_bin = _psd_slope_and_rq(dt_bot_b_clean, dx_bin, kmin, kmax_bin)\n",
    "\n",
    "# ------------------- Compute metrics: SLIDING WINDOW ----------------------\n",
    "met_top_sw = _metrics_from_series(delta_top_sw, dx_raw)\n",
    "met_bot_sw = _metrics_from_series(delta_bot_sw, dx_raw)\n",
    "\n",
    "psd_top_sw = _psd_slope_and_rq(delta_top_sw, dx_raw, kmin, kmax_raw)\n",
    "psd_bot_sw = _psd_slope_and_rq(delta_bot_sw, dx_raw, kmin, kmax_raw)\n",
    "\n",
    "# ------------------ Build final summary table -----------------------------\n",
    "rows = []\n",
    "\n",
    "def _add(interface, method, met, psd, dx_nm, kmax_used):\n",
    "    rows.append(dict(\n",
    "        Interface=interface,\n",
    "        Method=method,\n",
    "\n",
    "        Ra_nm=met[\"Ra\"],\n",
    "        Rq_nm=met[\"Rq\"],\n",
    "        PV_nm=met[\"PV\"],\n",
    "        xi_nm=met[\"xi_nm\"],\n",
    "\n",
    "        PSD_slope_m=psd[\"fit\"][\"slope\"],\n",
    "        PSD_points=psd[\"fit\"][\"n_points\"],\n",
    "\n",
    "        Rq_PSD_nm=psd[\"Rq_psd\"],\n",
    "        Rq_profile_nm=psd[\"Rq_profile\"],\n",
    "        Rq_ratio=psd[\"Rq_ratio\"],\n",
    "\n",
    "        dx_nm=dx_nm,\n",
    "        fit_band_min_nm1=kmin,\n",
    "        fit_band_max_nm1=kmax_used\n",
    "    ))\n",
    "\n",
    "# TOP interface rows\n",
    "_add(\"Top QW interface\", \"Raw\",    met_top_raw, psd_top_raw, dx_raw, kmax_raw)\n",
    "_add(\"Top QW interface\", \"Binned\", met_top_bin, psd_top_bin, dx_bin, kmax_bin)\n",
    "_add(\"Top QW interface\", \"SW\",     met_top_sw,  psd_top_sw,  dx_raw, kmax_raw)\n",
    "\n",
    "# BOTTOM interface rows\n",
    "_add(\"Bottom QW interface\", \"Raw\",    met_bot_raw, psd_bot_raw, dx_raw, kmax_raw)\n",
    "_add(\"Bottom QW interface\", \"Binned\", met_bot_bin, psd_bot_bin, dx_bin, kmax_bin)\n",
    "_add(\"Bottom QW interface\", \"SW\",     met_bot_sw,  psd_bot_sw,  dx_raw, kmax_raw)\n",
    "\n",
    "combined = pd.DataFrame(rows)\n",
    "\n",
    "# ------------------ Save summary tables ----------------------------------\n",
    "csv_out  = outpath(\"QW_roughness_combined_table\", \"csv\")\n",
    "json_out = outpath(\"QW_roughness_combined_full\", \"json\")\n",
    "\n",
    "combined.to_csv(csv_out, index=False)\n",
    "\n",
    "with open(json_out, \"w\", encoding=\"utf-8\") as f:\n",
    "    json.dump({\"table\": rows, \"px_nm\": PX_NM}, f, indent=2)\n",
    "\n",
    "print(\"Saved:\")\n",
    "print(\" \", csv_out)\n",
    "print(\" \", json_out)\n",
    "\n",
    "# ------------------ Display table in Jupyter -----------------------------\n",
    "display(combined.style.format({\n",
    "    \"Ra_nm\": \"{:.4f}\", \"Rq_nm\": \"{:.4f}\", \"PV_nm\": \"{:.4f}\",\n",
    "    \"xi_nm\": \"{:.4f}\", \"PSD_slope_m\": \"{:.2f}\",\n",
    "    \"Rq_PSD_nm\": \"{:.4f}\", \"Rq_profile_nm\": \"{:.4f}\", \"Rq_ratio\": \"{:.3f}\",\n",
    "    \"dx_nm\": \"{:.4f}\"\n",
    "}))\n",
    "\n",
    "# ------------------ Optional Rq comparison plot -------------------------\n",
    "if MAKE_RQ_COMPARISON_PLOT:\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(10,4))\n",
    "    methods = [\"Raw\",\"Binned\",\"SW\"]\n",
    "    idx = np.arange(len(methods))\n",
    "\n",
    "    top_vals = [met_top_raw[\"Rq\"], met_top_bin[\"Rq\"], met_top_sw[\"Rq\"]]\n",
    "    bot_vals = [met_bot_raw[\"Rq\"], met_bot_bin[\"Rq\"], met_bot_sw[\"Rq\"]]\n",
    "\n",
    "    width = 0.35\n",
    "\n",
    "    ax.bar(idx-width/2, bot_vals, width, label=\"Bottom\", color=\"#1f77b4\")\n",
    "    ax.bar(idx+width/2, top_vals, width, label=\"Top\",    color=\"#ff7f0e\")\n",
    "\n",
    "    # annotate bars\n",
    "    for i, v in enumerate(bot_vals):\n",
    "        ax.text(i-width/2, v, f\"{v:.3f}\", ha=\"center\", va=\"bottom\", fontsize=8)\n",
    "    for i, v in enumerate(top_vals):\n",
    "        ax.text(i+width/2, v, f\"{v:.3f}\", ha=\"center\", va=\"bottom\", fontsize=8)\n",
    "\n",
    "    ax.set_xticks(idx)\n",
    "    ax.set_xticklabels(methods)\n",
    "    ax.set_ylabel(\"RMS Roughness Rq (nm)\")\n",
    "    ax.set_title(\"QW Interface Roughness: Raw vs Binned vs Sliding-Window\")\n",
    "    ax.legend()\n",
    "    fig.tight_layout()\n",
    "\n",
    "    savefig(fig, \"QW_roughness_Rq_comparison\")\n",
    "    plt.show()"
   ]
